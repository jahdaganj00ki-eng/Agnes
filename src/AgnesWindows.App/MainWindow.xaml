<Window
    x:Class="AgnesWindows.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AgnesWindows.UI.ViewModels"
    xmlns:views="using:AgnesWindows.UI.Views"
    xmlns:converters="using:AgnesWindows.UI.Converters"
    mc:Ignorable="d"
    Title="Agnes Windows"
    MinWidth="1000"
    MinHeight="700"
    Width="1280"
    Height="850">

    <Window.Resources>
        <converters:EditImageStateToVisibilityConverter x:Key="StateToVisibilityConverter" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation -->
        <NavigationView
            Grid.Row="0"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            Background="{StaticResource CardBackgroundBrush}"
            SelectionChanged="NavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Edit Image" Tag="Edit" IsSelected="True" Icon="Edit"/>
                <NavigationViewItem Content="History" Tag="History" Icon="Clock"/>
                <NavigationViewItem Content="Settings" Tag="Settings" Icon="Setting"/>
            </NavigationView.MenuItems>
        </NavigationView>

        <!-- Main Content Area -->
        <Frame x:Name="ContentFrame" Grid.Row="1" Margin="16" />

        <!-- Input Bar (Fixed at bottom for Edit page) -->
        <Border
            x:Name="InputBar"
            Grid.Row="2"
            Background="{StaticResource CardBackgroundBrush}"
            Padding="16"
            Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Idle, Converter={StaticResource StateToVisibilityConverter}}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    PlaceholderText="Describe your edit..."
                    BorderBrush="Transparent"
                    Background="#2C2C2E"
                    CornerRadius="8"
                    Padding="12,8"
                    Text="{Binding UserPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="OnPromptKeyDown"/>

                <Button
                    Grid.Column="1"
                    Content="📎"
                    Width="48"
                    Height="48"
                    CornerRadius="24"
                    Background="{StaticResource AccentBlueBrush}"
                    Click="OnAttachImageClick"
                    ToolTipService.ToolTip="Attach Image"/>

                <Button
                    Grid.Column="2"
                    Content="Send"
                    Width="96"
                    Height="48"
                    CornerRadius="24"
                    Background="{StaticResource AccentCyanBrush}"
                    Click="OnSendClick"
                    IsEnabled="{Binding State, Converter={StaticResource StateToEnabledConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>