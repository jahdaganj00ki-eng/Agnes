<Page
    x:Class="AgnesWindows.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AgnesWindows.UI.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Spacing="24" MaxWidth="600">
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>

            <!-- API Key Section -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="API Configuration" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Enter your Agnes AI API key to use the production backend. Leave empty to use mock backend." 
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="13"/>
                    <TextBox x:Name="ApiKeyBox" PlaceholderText="Enter API Key (sk-...)" 
                             BorderBrush="Transparent" Background="#2C2C2E" CornerRadius="8" Padding="12,8"
                             Text="{Binding ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock x:Name="ApiKeyStatus" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Backend Selection -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Backend" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <RadioButton Content="Mock Backend (Offline)" GroupName="Backend" IsChecked="{Binding UseMockBackend, Mode=TwoWay}"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                    <RadioButton Content="Production API (Requires API Key)" GroupName="Backend" IsChecked="{Binding UseProductionBackend, Mode=TwoWay}"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton Content="Light" GroupName="Theme" IsChecked="{Binding Theme, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Light}"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                        <RadioButton Content="Dark" GroupName="Theme" IsChecked="{Binding Theme, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Dark}"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                        <RadioButton Content="System" GroupName="Theme" IsChecked="{Binding Theme, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=System}"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Default Aspect Ratio -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Default Aspect Ratio" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <ComboBox x:Name="AspectRatioCombo" SelectedItem="{Binding DefaultAspectRatio, Mode=TwoWay}"
                              Background="#2C2C2E" BorderBrush="Transparent" CornerRadius="8"
                              HorizontalAlignment="Left" Width="200">
                        <ComboBoxItem Content="1:1 (Square)"/>
                        <ComboBoxItem Content="16:9 (Landscape)"/>
                        <ComboBoxItem Content="9:16 (Portrait)"/>
                        <ComboBoxItem Content="4:3"/>
                        <ComboBoxItem Content="3:4"/>
                        <ComboBoxItem Content="3:2"/>
                        <ComboBoxItem Content="21:9 (Ultrawide)"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button Content="Save Settings" Width="150" Height="44" CornerRadius="22"
                    Background="{StaticResource AccentCyanBrush}" Foreground="Black" FontWeight="SemiBold"
                    HorizontalAlignment="Right" Click="OnSaveClick"/>
        </StackPanel>
    </ScrollViewer>
</Page>