<Page
    x:Class="AgnesWindows.App.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AgnesWindows.App.ViewModels"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:HistoryViewModel/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Generation History" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <Button Content="Clear All" Width="100" Height="40" CornerRadius="20" Background="{StaticResource ErrorBrush}" Foreground="White" 
                        Command="{Binding ClearHistoryCommand}" Visibility="{Binding Entries.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,8,0,0">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Image Preview -->
                                <Border Grid.Column="0" Width="120" Height="90" CornerRadius="8" Background="#2C2C2E" Margin="0,0,16,0">
                                    <Image Source="{Binding ImageUrl}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Details -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{Binding OriginalPrompt}" FontSize="16" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" MaxWidth="500"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MMM dd, HH:mm}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding AspectRatio}" FontSize="12" Foreground="{StaticResource AccentCyanBrush}"/>
                                        <TextBlock Text="•" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding GenerationTime, StringFormat='{}{0:0.0}s'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding IsImageToImage, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Image-to-Image|Text-to-Image'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                                    <Button Content="📋" Width="40" Height="40" CornerRadius="20" Background="Transparent" ToolTipService.ToolTip="Copy Prompt"/>
                                    <Button Content="🗑️" Width="40" Height="40" CornerRadius="20" Background="Transparent" Foreground="{StaticResource ErrorBrush}"
                                            Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Page}}"
                                            CommandParameter="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State -->
            <Border Visibility="{Binding Entries.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=inverse}" 
                    Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="40" Margin="0,40,0,0">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <FontIcon Glyph="🕐" FontSize="48" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="No History Yet" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Your generated images will appear here" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>