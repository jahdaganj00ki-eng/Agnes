<UserControl
    x:Class="AgnesWindows.UI.Views.ActionToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinHeight="48">

    <StackPanel 
        Orientation="Horizontal" 
        Spacing="12" 
        HorizontalAlignment="Center"
        VerticalAlignment="Center">
        <Button Content="👍" Width="40" Height="40" Background="Transparent" ToolTipService.ToolTip="Like"/>
        <Button Content="👎" Width="40" Height="40" Background="Transparent" ToolTipService.ToolTip="Dislike"/>
        <Button Content="📋" Width="40" Height="40" Background="Transparent" ToolTipService.ToolTip="Copy"/>
        <Button Content="↗️" Width="40" Height="40" Background="Transparent" ToolTipService.ToolTip="Share"/>
    </StackPanel>
</UserControl>
